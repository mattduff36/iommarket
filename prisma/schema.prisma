generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth & Users
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  DEALER
  ADMIN
}

enum DealerTier {
  STARTER
  PRO
}

enum DealerReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum DealerReviewerType {
  REGISTERED
  ANONYMOUS
}

model User {
  id             String    @id @default(cuid())
  authUserId     String    @unique
  email          String    @unique
  name           String?
  phone          String?
  bio            String?
  avatarUrl      String?
  role           UserRole  @default(USER)
  regionId       String?
  disabledAt     DateTime?
  disabledReason String?
  deletedAt      DateTime?
  deletionReason String?
  deletionRequestedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  region              Region?              @relation(fields: [regionId], references: [id])
  listings            Listing[]
  dealerProfile       DealerProfile?
  reports             Report[]
  favourites          Favourite[]
  savedSearches       SavedSearch[]
  listingViews        ListingView[]
  dealerReviews       DealerReview[]
  listingStatusEvents ListingStatusEvent[]

  @@index([authUserId])
  @@index([email])
}

model DealerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  slug      String   @unique
  bio       String?
  website   String?
  phone     String?
  logoUrl   String?
  verified  Boolean  @default(false)
  tier      DealerTier @default(STARTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings      Listing[]
  subscriptions Subscription[]
  reviews       DealerReview[]

  @@index([slug])
}

// ---------------------------------------------------------------------------
// Geography
// ---------------------------------------------------------------------------

model Region {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users    User[]
  listings Listing[]

  @@index([slug])
}

// ---------------------------------------------------------------------------
// Categories & Attributes (EAV)
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  attributeDefinitions AttributeDefinition[]
  listings             Listing[]

  @@index([slug])
  @@index([parentId])
}

model AttributeDefinition {
  id         String  @id @default(cuid())
  categoryId String
  name       String
  slug       String
  dataType   String  // text, number, select, boolean
  required   Boolean @default(false)
  options    String? // JSON-encoded options for select type
  sortOrder  Int     @default(0)

  category Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  values   ListingAttributeValue[]

  @@unique([categoryId, slug])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Listings
// ---------------------------------------------------------------------------

enum ListingStatus {
  DRAFT
  PENDING
  APPROVED
  LIVE
  EXPIRED
  TAKEN_DOWN
  SOLD
}

enum ListingStatusEventSource {
  USER
  ADMIN
  SYSTEM
  PAYMENT
}

model Listing {
  id          String        @id @default(cuid())
  userId      String
  dealerId    String?
  categoryId  String
  regionId    String
  title       String
  description String
  price       Int           // stored in pence
  status      ListingStatus @default(DRAFT)
  featured    Boolean       @default(false)
  slug        String?
  viewCount   Int           @default(0)
  expiresAt   DateTime?
  soldAt      DateTime?
  trustDeclarationAccepted   Boolean  @default(false)
  trustDeclarationAcceptedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  dealer   DealerProfile? @relation(fields: [dealerId], references: [id])
  category Category       @relation(fields: [categoryId], references: [id])
  region   Region         @relation(fields: [regionId], references: [id])

  images          ListingImage[]
  attributeValues ListingAttributeValue[]
  payments        Payment[]
  reports         Report[]
  favouritedBy    Favourite[]
  views           ListingView[]
  statusEvents    ListingStatusEvent[]

  @@index([categoryId, regionId, status])
  @@index([status])
  @@index([price])
  @@index([slug])
  @@index([userId])
  @@index([dealerId])
  @@index([createdAt])
}

model ListingStatusEvent {
  id              String                   @id @default(cuid())
  listingId       String
  fromStatus      ListingStatus?
  toStatus        ListingStatus
  changedByUserId String?
  source          ListingStatusEventSource
  notes           String?
  createdAt       DateTime                 @default(now())

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([listingId, createdAt])
  @@index([changedByUserId, createdAt])
  @@index([toStatus, createdAt])
}

model ListingImage {
  id        String @id @default(cuid())
  listingId String
  url       String
  publicId  String // Cloudinary public ID
  order     Int    @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingAttributeValue {
  id                    String @id @default(cuid())
  listingId             String
  attributeDefinitionId String
  value                 String

  listing             Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attributeDefinition AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)

  @@unique([listingId, attributeDefinitionId])
  @@index([attributeDefinitionId, value])
}

// ---------------------------------------------------------------------------
// Payments & Subscriptions
// ---------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentType {
  LISTING
  FEATURED
  SUPPORT
}

model Payment {
  id              String        @id @default(cuid())
  listingId       String
  stripePaymentId String        @unique
  amount          Int           // in pence
  currency        String        @default("gbp")
  type            PaymentType   @default(LISTING)
  status          PaymentStatus @default(PENDING)
  idempotencyKey  String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])

  @@index([listingId])
  @@index([stripePaymentId])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  INCOMPLETE
}

model Subscription {
  id                   String             @id @default(cuid())
  dealerId             String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  dealer DealerProfile @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([dealerId])
  @@index([stripeSubscriptionId])
}

// ---------------------------------------------------------------------------
// Moderation
// ---------------------------------------------------------------------------

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

model Report {
  id            String       @id @default(cuid())
  listingId     String
  reporterId    String?
  reporterEmail String
  reason        String
  status        ReportStatus @default(OPEN)
  adminNotes    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  listing  Listing @relation(fields: [listingId], references: [id])
  reporter User?   @relation(fields: [reporterId], references: [id])

  @@index([listingId])
  @@index([status])
}

model DealerReview {
  id                String             @id @default(cuid())
  dealerId          String
  reviewerUserId    String?
  reviewerDeviceId  String?
  reviewerType      DealerReviewerType
  reviewerName      String?
  rating            Int
  comment           String?
  status            DealerReviewStatus @default(PENDING)
  adminNotes        String?
  moderatedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  dealer   DealerProfile @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  reviewer User?         @relation(fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@unique([dealerId, reviewerUserId])
  @@unique([dealerId, reviewerDeviceId])
  @@index([dealerId, status, createdAt])
  @@index([status, createdAt])
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model SavedSearch {
  id              String   @id @default(cuid())
  userId          String
  name            String
  queryParamsJson Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ListingView {
  id         String   @id @default(cuid())
  listingId  String
  viewerId   String?
  viewerHash String
  createdAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewer  User?   @relation(fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([listingId, createdAt])
  @@index([viewerHash, createdAt])
}

model WaitlistUser {
  id        String   @id @default(cuid())
  email     String   @unique
  interests Json
  source    String   @default("coming_soon_page")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Admin Audit Log
// ---------------------------------------------------------------------------

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// CMS Content Pages
// ---------------------------------------------------------------------------

enum ContentPageStatus {
  DRAFT
  PUBLISHED
}

model ContentPage {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  markdown        String
  metaTitle       String?
  metaDescription String?
  status          ContentPageStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([slug])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Site Settings (DB-backed overrides)
// ---------------------------------------------------------------------------

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@index([key])
}
