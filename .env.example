# =============================================================================
# iTrader — Environment Variables Reference
# Copy this file to .env.local for local development.
# For production (Vercel), set these via the Vercel dashboard or CLI.
# NEVER commit .env.local or .env.production to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Direct connection (used for migrations/seeds). No pooling.
DATABASE_URL="postgres://postgres.[ref]:[password]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"

# Prisma uses this pooled URL for runtime queries
POSTGRES_URL="postgres://postgres.[ref]:[password]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x"
POSTGRES_URL_NON_POOLING="postgres://postgres.[ref]:[password]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres?sslmode=require"
POSTGRES_PRISMA_URL="postgres://postgres.[ref]:[password]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Individual Postgres credentials (used by Vercel Postgres integration)
POSTGRES_DATABASE="postgres"
POSTGRES_HOST="db.[ref].supabase.co"
POSTGRES_PASSWORD="your-db-password"
POSTGRES_USER="postgres"

# -----------------------------------------------------------------------------
# Supabase Authentication
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Server-only — never expose to client
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Secret for the Supabase "Send Email" auth hook (set in Supabase Auth → Hooks)
SUPABASE_AUTH_HOOK_SECRET="v1,whsec_..."

# -----------------------------------------------------------------------------
# Stripe Payments
# NOTE: Use sk_test_... / pk_test_... keys for local development to avoid
# real charges. Switch to live keys only for production.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_DEALER_PRICE_ID="price_..."          # Legacy / fallback dealer subscription
STRIPE_DEALER_STARTER_PRICE_ID="price_..."  # Dealer Starter tier
STRIPE_DEALER_PRO_PRICE_ID="price_..."      # Dealer Pro tier
STRIPE_FEATURED_PRICE_ID="price_..."        # Featured listing add-on

# Listing fee in pence (e.g. 499 = £4.99). Overridable via Admin → Settings.
LISTING_FEE_PENCE="499"

# Free launch window: all private listings are free until this ISO timestamp.
# Set to a past date (or remove) to disable time-based free window.
LAUNCH_FREE_UNTIL="2026-03-31T23:59:59.000Z"

# How many days a free private listing remains active before expiring.
FREE_LISTING_WINDOW_DAYS="30"

# -----------------------------------------------------------------------------
# Cloudinary — Image Uploads
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="iommarket_unsigned"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# -----------------------------------------------------------------------------
# Email — Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="iTrader <no-reply@yourdomain.com>"
RESEND_REPLY_TO_EMAIL="support@yourdomain.com"
RESEND_REPORTS_TO_EMAIL="moderation@yourdomain.com"
# Comma-separated list of addresses that receive waitlist notifications
RESEND_WAITLIST_TO_EMAIL="admin1@yourdomain.com, admin2@yourdomain.com"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Local dev: http://localhost:4000 | Production: https://itrader.im
NEXT_PUBLIC_APP_URL="http://localhost:4000"

# Isle of Man ICO data controller registration reference (shown in footer)
NEXT_PUBLIC_IOM_DATA_CONTROLLER_REF="Pending registration"

# -----------------------------------------------------------------------------
# Dev access
# -----------------------------------------------------------------------------
# Password to unlock the full site at /dev/auth (bypasses holding page)
DEV_PASS="your-dev-password"

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# Featured listing fee in pence. Defaults to 1000 if not set.
# FEATURED_FEE_PENCE="1000"

# Monitoring alert recipients (comma-separated). Falls back to RESEND_REPORTS_TO_EMAIL.
# MONITORING_ALERT_EMAILS="ops@example.com,alerts@example.com"

# Optional webhook destination for monitoring alerts (Slack/Discord/custom endpoint).
# MONITORING_ALERT_WEBHOOK_URL="https://hooks.example.com/services/..."

# Minimum severity that triggers alerts: LOW | MEDIUM | HIGH | CRITICAL
# MONITORING_ALERT_MIN_SEVERITY="HIGH"

# Cooldown between alerts for the same issue (minutes)
# MONITORING_ALERT_COOLDOWN_MINUTES="30"
